{
  "name": "hook",
  "version": "0.1.0",
  "description": "Windows-first Tauri desktop capture, sticker editing, and visual workflow workspace.",
  "type": "module",
  "author": "yamiyu",
  "homepage": "https://github.com/aiaimimi0920/Hook#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/aiaimimi0920/Hook.git"
  },
  "bugs": {
    "url": "https://github.com/aiaimimi0920/Hook/issues"
  },
  "keywords": [
    "tauri",
    "solidjs",
    "windows",
    "screenshot",
    "workflow"
  ],
  "scripts": {
    "dev": "cmd /d /s /c \"pushd %npm_config_local_prefix% && call node_modules\\.bin\\vite.cmd --port 1420 --strictPort\"",
    "build": "cmd /d /s /c \"pushd %npm_config_local_prefix% && call scripts\\build-static.cmd\"",
    "start": "cmd /d /s /c \"pushd %npm_config_local_prefix% && call scripts\\serve-static.cmd --port 1420 --root .output/public\"",
    "serve:static": "cmd /d /s /c \"pushd %npm_config_local_prefix% && call scripts\\serve-static.cmd --port 1420 --root .output/public\"",
    "dev:tauri": "cmd /d /s /c \"pushd %npm_config_local_prefix% && call scripts\\dev-tauri.cmd\"",
    "tauri": "\"%npm_config_local_prefix%\\scripts\\run-tauri.cmd\"",
    "test": "cmd /d /s /c \"pushd %npm_config_local_prefix% && node_modules\\.bin\\vitest.cmd run --pool threads --maxWorkers 1 --no-file-parallelism\"",
    "test:watch": "cmd /d /s /c \"pushd %npm_config_local_prefix% && node_modules\\.bin\\vitest.cmd watch --pool threads --maxWorkers 1 --no-file-parallelism\"",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint src",
    "verify:local": "cmd /d /s /c \"pushd %npm_config_local_prefix% && call npm run typecheck && call npm test && call npm run build && call build-hook-release.bat\""
  },
  "license": "MIT",
  "dependencies": {
    "@tauri-apps/api": "2.11.0",
    "solid-js": "^1.9.14"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.3.2",
    "@tauri-apps/cli": "2.11.4",
    "@types/node": "^22.20.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.4",
    "eslint-plugin-solid": "^0.14.5",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.4.3",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "picomatch": "4.0.5",
    "rollup": "4.62.2"
  }
}
